<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %> - ECOGENERATION</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <main class="admin-container">
    <section class="admin-login-box">
      <header class="admin-header">
        <h1> ADMIN ECOGENERATION</h1>
        <p>Painel de Administração</p>
      </header>
      
      <% if (erro) { %>
        <aside class="alert alert-error">
          <%= erro %>
        </aside>
      <% } %>
      
      <form method="POST" action="/admin-login" class="admin-form">
        <p class="form-group">
          <label for="usuario">Usuário</label>
          <input 
            type="text" 
            id="usuario" 
            name="usuario" 
            placeholder="Digite o usuário" 
            required
          >
        </p>
        
        <p class="form-group">
          <label for="senha">Senha</label>
          <input 
            type="password" 
            id="senha" 
            name="senha" 
            placeholder="Digite a senha" 
            required
          >
          <label class="mostrar-senha-label">
            <input type="checkbox" onchange="toggleSenha('senha', this)"> Mostrar senha
          </label>
        </p>
        
        <button type="submit" class="btn btn-primary btn-block">
          Entrar
        </button>
      </form>
      
      <footer class="admin-footer">
        <a href="/">Voltar à página inicial</a>
      </footer>
    </section>
  </main>

  <script src="/js/login.js"></script>
  <script src="/js/senha-toggle.js"></script>
</body>
</html>
