<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %> — EcoGeneration</title>
  <meta name="description" content="Resultados de busca de produtos solares na EcoGeneration.">
  <meta name="robots" content="index, follow">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/ecoloja.css">
  <link rel="apple-touch-icon" href="/imagens/favicon2.png">
  <link rel="icon" href="/imagens/favicon2.png" type="image/png">
  <meta property="og:locale" content="pt_BR">
  <meta property="og:type" content="website">
  <meta property="og:title" content="<%= titulo %> — EcoGeneration">
  <meta property="og:description" content="Resultados de busca de produtos solares.">
  <meta property="og:url" content="https://ecogeneration-final-4hh3.onrender.com">
  <meta property="og:site_name" content="EcoGeneration">
  <meta property="og:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= titulo %> — EcoGeneration">
  <meta name="twitter:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#2e7d32">
</head>
<body>
  <a href="#conteudo-principal" class="skip-link">Ir para o conteúdo principal</a>

  <%- include('../partials/header') %>

  <main id="conteudo-principal" class="ecoloja-container">

    <header class="ecoloja-header">
      <h1>Resultados da Busca</h1>
      <p class="busca-termo">
        <% if (termo) { %>
          Mostrando resultados para: <strong>"<%= termo %>"</strong>
          <% if (total > 0) { %>
            (<%= total %> resultado<%= total !== 1 ? 's' : '' %> encontrado<%= total !== 1 ? 's' : '' %>)
          <% } %>
        <% } %>
      </p>
    </header>

    <!-- Mensagem quando não há resultados ou erro -->
    <% if (mensagem) { %>
      <section class="busca-vazia" role="alert">
        <div class="busca-vazia-content">
          <p><%= mensagem %></p>
          <a href="/ecoloja" class="btn-voltar-loja">Ver todos os produtos</a>
        </div>
      </section>
    <% } else if (resultados && resultados.length > 0) { %>

      <!-- Grid de produtos -->
      <section class="produtos-grid" role="list" aria-label="Produtos encontrados">
        <% resultados.forEach(function(produto) { %>
          <article class="produto-card" role="listitem">
            <header class="produto-categoria">
              <span><%= produto.categoria_produto %></span>
            </header>
            <figure class="produto-figura">
              <img src="/imagens/<%= produto.imagem_produto %>"
                   alt="Foto do produto: <%= produto.nome_produto %>"
                   class="produto-img"
                   loading="lazy">
            </figure>
            <section class="produto-info">
              <h2 class="produto-nome"><%= produto.nome_produto %></h2>
              <p class="produto-desc"><%= produto.descricao_produto %></p>
              <footer class="produto-rodape">
                <strong class="produto-preco" aria-label="Preço: R$ <%= produto.preco_produto %>">
                  R$ <%= produto.preco_produto %>
                </strong>
                <a href="/produto/<%= produto.id_produto %>"
                   class="btn-comprar"
                   aria-label="Ver detalhes do produto <%= produto.nome_produto %>">
                  Ver produto
                </a>
              </footer>
            </section>
          </article>
        <% }) %>
      </section>

      <!-- Paginação -->
      <% if (totalPages > 1) { %>
        <nav class="paginacao" aria-label="Paginação de resultados">
          <% if (page > 1) { %>
            <a href="/search?q=<%= encodeURIComponent(termo) %>&page=<%= page - 1 %>" class="paginacao-prev">
              ← Anterior
            </a>
          <% } %>

          <div class="paginacao-info">
            Página <%= page %> de <%= totalPages %>
          </div>

          <% if (page < totalPages) { %>
            <a href="/search?q=<%= encodeURIComponent(termo) %>&page=<%= page + 1 %>" class="paginacao-next">
              Próxima →
            </a>
          <% } %>
        </nav>
      <% } %>

    <% } %>

    <!-- Link para voltar -->
    <section class="busca-acoes">
      <a href="/ecoloja" class="btn-voltar-loja">Ver todos os produtos</a>
      <a href="/" class="btn-voltar-home">Voltar à página inicial</a>
    </section>

  </main>

  <%- include('../partials/footer') %>

  <style>
    .busca-termo {
      font-size: 0.95rem;
      color: #666;
      margin-top: 0.5rem;
    }

    [data-theme="dark"] .busca-termo {
      color: #aaa;
    }

    .busca-vazia {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 300px;
      background: #f9f9f9;
      border-radius: 12px;
      margin: 2rem 0;
      padding: 2rem;
      text-align: center;
    }

    [data-theme="dark"] .busca-vazia {
      background: #1e1e1e;
    }

    .busca-vazia-content p {
      font-size: 1.1rem;
      color: #666;
      margin-bottom: 1.5rem;
    }

    [data-theme="dark"] .busca-vazia-content p {
      color: #aaa;
    }

    .busca-acoes {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin-top: 2rem;
      flex-wrap: wrap;
    }

    .btn-voltar-loja,
    .btn-voltar-home {
      background: #2e7d32;
      color: #ffffff;
      border-radius: 8px;
      padding: 0.6rem 1.5rem;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.2s;
      display: inline-block;
    }

    .btn-voltar-loja:hover,
    .btn-voltar-home:hover {
      background: #1b5e20;
    }

    [data-theme="dark"] .btn-voltar-loja,
    [data-theme="dark"] .btn-voltar-home {
      background: #2e7d32;
    }

    [data-theme="dark"] .btn-voltar-loja:hover,
    [data-theme="dark"] .btn-voltar-home:hover {
      background: #1b5e20;
    }

    .paginacao {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      margin-top: 2rem;
      padding: 1.5rem;
      flex-wrap: wrap;
    }

    .paginacao a {
      background: #f5f5f5;
      color: #333;
      padding: 0.5rem 1rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      transition: background 0.2s;
    }

    .paginacao a:hover {
      background: #e0e0e0;
    }

    [data-theme="dark"] .paginacao a {
      background: #424242;
      color: #ffffff;
    }

    [data-theme="dark"] .paginacao a:hover {
      background: #616161;
    }

    .paginacao-info {
      color: #666;
      font-size: 0.9rem;
      min-width: 120px;
      text-align: center;
    }

    [data-theme="dark"] .paginacao-info {
      color: #aaa;
    }

    @media (max-width: 768px) {
      .busca-vazia {
        min-height: 200px;
        padding: 1.5rem;
      }

      .busca-acoes {
        flex-direction: column;
        align-items: center;
      }

      .btn-voltar-loja,
      .btn-voltar-home {
        width: 100%;
        text-align: center;
      }

      .paginacao {
        flex-direction: column;
        gap: 0.5rem;
      }

      .paginacao a {
        width: 100%;
        text-align: center;
      }
    }
  </style>
</body>
</html>
