<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Resultado do Diagnóstico — EcoGeneration</title>
  <meta name="description" content="Veja seu nível de autonomia energética e os produtos recomendados especialmente para você.">
  <meta name="robots" content="noindex, follow">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/resultado.css">
  <link rel="apple-touch-icon" href="/imagens/favicon2.png">
  <link rel="icon" href="/imagens/favicon2.png" type="image/png">
  <meta property="og:locale" content="pt_BR">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Resultado do Diagnóstico — EcoGeneration">
  <meta property="og:description" content="Veja seu nível de autonomia energética e os produtos recomendados especialmente para você.">
  <meta property="og:url" content="https://ecogeneration-final-4hh3.onrender.com/diagnostico">
  <meta property="og:site_name" content="EcoGeneration">
  <meta property="og:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <meta property="og:image:secure_url" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="EcoGeneration — Resultado do Diagnóstico">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Resultado do Diagnóstico — EcoGeneration">
  <meta name="twitter:description" content="Veja seu nível de autonomia energética e os produtos recomendados para você.">
  <meta name="twitter:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#2e7d32">
</head>
<body>

  <%- include('../partials/header') %>

  <main class="resultado-container" id="conteudo-principal" tabindex="-1">

    <section class="resultado-header">
      <h1>Resultado do Diagnóstico</h1>
    </section>

    <%
      const labelPrioridade = {
        iluminacao:   'iluminação dos cômodos',
        carregamento: 'carregamento de celular e internet',
        climatizacao: 'ventilação e climatização',
        geladeira:    'conservação de alimentos',
        trabalho:     'trabalho e estudo em casa'
      };
      const vulnPct  = Math.round((vulnerabilidade / 10) * 100);
      const prepPct  = Math.round((preparo / 10) * 100);
      const vulnLabel = vulnerabilidade >= 7 ? 'Alta' : vulnerabilidade >= 3 ? 'Média' : 'Baixa';
      const prepLabel = preparo >= 7 ? 'Alto'  : preparo >= 3 ? 'Médio' : 'Baixo';
    %>

    <!-- Resultado do perfil -->
    <section aria-live="assertive" aria-atomic="true" class="resultado-perfil">

      <% if (perfil === 'independente') { %>
        <article class="resultado alta" role="status">
          <h2>🏆 Parabéns — você já é independente da rede!</h2>
          <p>Você já conta com uma boa estrutura de proteção energética. Os produtos abaixo são complementos práticos para deixar sua autonomia ainda mais completa.</p>
        </article>

      <% } else if (perfil === 'critico') { %>
        <article class="resultado baixa" role="status">
          <h2>⚠️ Situação crítica de dependência</h2>
          <p>Você sofre com quedas frequentes ou longas e ainda não tem proteção. A boa notícia: pequenas soluções já fazem grande diferença — e custam menos do que você imagina.</p>
        </article>

      <% } else if (perfil === 'medio') { %>
        <article class="resultado media" role="status">
          <h2>⚡ Você está no caminho certo</h2>
          <p>Você tem alguma proteção, mas ainda é vulnerável em quedas mais longas ou frequentes. Os produtos abaixo vão fechar essa lacuna.</p>
        </article>

      <% } else { %>
        <article class="resultado media" role="status">
          <h2>🌱 Hora de se preparar antes de precisar</h2>
          <p>Você raramente enfrenta quedas agora, mas estar preparado custa muito menos do que remediar depois. Veja opções simples e acessíveis.</p>
        </article>
      <% } %>

      <!-- Medidores das duas dimensões -->
      <section class="dimensoes" aria-label="Detalhes do seu diagnóstico">

        <figure class="dimensao">
          <figcaption class="dimensao-titulo">Vulnerabilidade a quedas</figcaption>
          <meter class="barra-vuln"
                 min="0" max="10"
                 value="<%= vulnerabilidade %>"
                 aria-label="Vulnerabilidade: <%= vulnLabel %>">
          </meter>
          <output class="dimensao-valor"><%= vulnLabel %></output>
        </figure>

        <figure class="dimensao">
          <figcaption class="dimensao-titulo">Preparo atual</figcaption>
          <meter class="barra-prep"
                 min="0" max="10"
                 value="<%= preparo %>"
                 aria-label="Preparo: <%= prepLabel %>">
          </meter>
          <output class="dimensao-valor"><%= prepLabel %></output>
        </figure>

      </section>

      <% if (prioridade && labelPrioridade[prioridade]) { %>
        <p class="resultado-foco">
          <% if (perfil === 'independente') { %>
            Com base na sua estrutura atual, selecionamos complementos para <strong><%= labelPrioridade[prioridade] %></strong>.
          <% } else { %>
            Sua prioridade é <strong><%= labelPrioridade[prioridade] %></strong> — os produtos abaixo foram selecionados com isso em mente.
          <% } %>
        </p>
      <% } %>

    </section>

    <!-- Feedback de salvamento -->

    <!-- Produtos recomendados -->
    <section class="recomendacoes" aria-labelledby="titulo-recomendacoes">
      <h2 id="titulo-recomendacoes">Produtos selecionados para o seu perfil</h2>

      <% if (!produtosRecomendados || produtosRecomendados.length === 0) { %>
        <p class="sem-produtos">
          Nenhum produto encontrado.
          <a href="/ecoloja">Acesse a EcoLoja</a> para ver todos os produtos.
        </p>
      <% } else { %>
        <ol class="produtos-grid" role="list">
          <% produtosRecomendados.forEach(function(produto) { %>
            <li class="produto-card" role="listitem">
              <span class="produto-categoria"><%= produto.categoria_produto %></span>
              <figure class="produto-figura">
                <img src="/imagens/<%= produto.imagem_produto %>"
                     alt="<%= produto.nome_produto %>"
                     class="produto-img"
                     loading="lazy">
              </figure>
              <article class="produto-info">
                <h3 class="produto-nome"><%= produto.nome_produto %></h3>
                <p class="produto-desc"><%= produto.descricao_produto %></p>
                   <strong class="produto-preco"
                          aria-label="Preço: R$ <%= produto.preco_produto %>">
                    R$ <%= produto.preco_produto %>
                  </strong>
                  <a href="/produto/<%= produto.id_produto %>"
                     class="btn-comprar"
                     aria-label="Ver detalhes de <%= produto.nome_produto %>">
                    Ver produto
                  </a>
              
              </article>
            </li>
          <% }); %>
        </ol>
      <% } %>

    </section>

    <!-- Ações pós-resultado -->
    <nav class="acoes" aria-label="Ações pós-diagnóstico">
      <a href="/diagnostico" class="btn-voltar">Refazer Diagnóstico</a>
      <a href="/ecoloja" class="btn-home">Ver toda a loja</a>
    </nav>

  </main>

  <%- include('../partials/footer') %>

</body>
</html>
