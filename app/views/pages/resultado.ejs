<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Resultado do Diagnóstico — EcoGeneration</title>
  <meta name="description" content="Veja seu nível de autonomia energética e os produtos recomendados especialmente para você.">
  <meta name="robots" content="noindex, follow">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/resultado.css">
  <link rel="apple-touch-icon" href="/imagens/favicon2.png">
  <link rel="icon" href="/imagens/favicon2.png" type="image/png">
  <meta property="og:locale" content="pt_BR">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Resultado do Diagnóstico — EcoGeneration">
  <meta property="og:description" content="Veja seu nível de autonomia energética e os produtos recomendados especialmente para você.">
  <meta property="og:url" content="https://ecogeneration-final-4hh3.onrender.com/diagnostico">
  <meta property="og:site_name" content="EcoGeneration">
  <meta property="og:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <meta property="og:image:secure_url" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="EcoGeneration — Resultado do Diagnóstico">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Resultado do Diagnóstico — EcoGeneration">
  <meta name="twitter:description" content="Veja seu nível de autonomia energética e os produtos recomendados para você.">
  <meta name="twitter:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#2e7d32">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="resultado-container" id="conteudo-principal" tabindex="-1">

    <header class="resultado-header">
      <h1>Resultado do Diagnóstico</h1>
    </header>

    <!-- WCAG 4.1.3 — aria-live assertive anuncia o resultado para leitores de tela -->
    <section aria-live="assertive" aria-atomic="true">
      <% if (nivel === 'alta') { %>
        <section class="resultado alta" role="status">
          <h2>✅ Autonomia Energética: Alta</h2>
          <p>Você já tem boa estrutura energética. Os produtos abaixo vão elevar ainda mais sua independência da rede elétrica.</p>
        </section>
      <% } else if (nivel === 'media') { %>
        <section class="resultado media" role="status">
          <h2>⚡ Autonomia Energética: Média</h2>
          <p>Você tem alguma preparação, mas ainda depende bastante da rede. Com as soluções abaixo você dá um salto real de autonomia.</p>
        </section>
      <% } else { %>
        <section class="resultado baixa" role="status">
          <h2>⚠️ Autonomia Energética: Baixa</h2>
          <p>Você depende quase totalmente da rede elétrica. Comece com produtos acessíveis e portáteis — pequenas mudanças já fazem grande diferença.</p>
        </section>
      <% } %>

      <% const labelPrioridade = {
        iluminacao:   'iluminação',
        carregamento: 'carregamento de dispositivos',
        climatizacao: 'climatização',
        geladeira:    'conservação de alimentos',
        trabalho:     'trabalho em casa'
      }; %>
      <% if (prioridade && labelPrioridade[prioridade]) { %>
        <p class="resultado-foco">
          Com base na sua prioridade — <strong><%= labelPrioridade[prioridade] %></strong> — selecionamos os produtos mais indicados para o seu perfil.
        </p>
      <% } %>
    </section>

    <!-- Heurística Nielsen 1 — feedback claro de que o diagnóstico foi salvo -->
    <section class="diagnostico-salvo" role="status" aria-label="Diagnóstico salvo">
      <p>✓ Seu diagnóstico foi salvo com sucesso no seu perfil.</p>
    </section>

    <section class="recomendacoes" aria-labelledby="titulo-recomendacoes">
      <h2 id="titulo-recomendacoes">Produtos selecionados para o seu perfil</h2>
      <section class="produtos-grid" role="list">
        <% produtosRecomendados.forEach(function(produto) { %>
          <article class="produto-card" role="listitem">
            <header class="produto-categoria">
              <span><%= produto.categoria_produto %></span>
            </header>
            <figure class="produto-figura">
              <img src="/imagens/<%= produto.imagem_produto %>"
                   alt="Foto do produto: <%= produto.nome_produto %>"
                   class="produto-img"
                   loading="lazy">
            </figure>
            <section class="produto-info">
              <h3 class="produto-nome"><%= produto.nome_produto %></h3>
              <p class="produto-desc"><%= produto.descricao_produto %></p>
              <footer class="produto-rodape">
                <strong class="produto-preco" aria-label="Preço: R$ <%= produto.preco_produto %>">
                  R$ <%= produto.preco_produto %>
                </strong>
                <a href="/produto/<%= produto.id_produto %>"
                   class="btn-comprar"
                   aria-label="Ver detalhes do produto <%= produto.nome_produto %>">
                  Ver produto
                </a>
              </footer>
            </section>
          </article>
        <% }) %>
      </section>
    </section>

    <nav class="acoes" aria-label="Ações pós-diagnóstico">
      <a href="/diagnostico" class="btn-voltar">Refazer Diagnóstico</a>
      <a href="/ecoloja" class="btn-home">Ver toda a loja</a>
    </nav>

  </main>

  <%- include('../partials/footer') %>
</body>
</html>
