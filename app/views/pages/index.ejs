<!DOCTYPE html>
<html lang="pt-br" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EcoGeneration — Autonomia Energética para Todos</title>
  <meta name="description" content="Faça seu diagnóstico de autonomia energética e encontre soluções solares portáteis e acessíveis para sua realidade.">
  <meta name="robots" content="index, follow">
  <meta name="description" content="Plataforma de diagnóstico energético e loja de soluções solares portáteis. Descubra sua autonomia e encontre o produto ideal.">
  <meta name="robots" content="index, follow">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="apple-touch-icon" href="/imagens/favicon2.png">
  <link rel="icon" href="/imagens/favicon2.png" type="image/png">
  <%- include("../partials/open-graph") %>
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#2e7d32">
</head>
<body>
  <a href="#conteudo-principal" class="skip-link">Ir para o conteúdo principal</a>

  <%- include("../partials/header") %>

  <!-- ===== HERO CAROUSEL ===== -->
  <section class="hero-carousel" aria-label="Carrossel de banners">
    <section class="hero-slides">

      <!-- Banner 1: Loja -->
       
      <article class="hero-slide hero-banner hero-banner-green">
        <figure class="hero-img-wrap">
          <img src="/imagens/itens-para-o-bunner.png" alt="Equipamentos solares portáteis">
        </figure>
        <section class="hero-copy">
          <p class="hero-label">Energia limpa e acessível</p>
          <h1>Sustentabilidade<br><span>que cabe no<br>dia a dia</span></h1>
          <a href="/ecoloja" class="hero-btn">Ver produtos</a>
        </section>
      </article>

      <!-- Banner 2: Diagnóstico -->
      <article class="hero-slide hero-banner hero-banner-blue">
        <figure class="hero-img-wrap">
          <img src="/imagens/celular-bunner.svg" alt="Diagnóstico energético no celular">
        </figure>
        <section class="hero-copy">
          <p class="hero-label">Em menos de 1 minuto</p>
          <h1>Descubra sua<br><span>autonomia<br>energética</span></h1>
          <a href="/diagnostico" class="hero-btn hero-btn-blue">Fazer diagnóstico</a>
        </section>
      </article>

    </section>
    <button type="button" class="hero-carousel-button hero-prev" aria-label="Anterior">‹</button>
    <button type="button" class="hero-carousel-button hero-next" aria-label="Próximo">›</button>
  </section>

  <main id="conteudo-principal">

    <!-- ===== POR QUE ECOGENERATION ===== -->
    <section class="why-ecogeneration">
      <h2 class="why">Por que escolher EcoGeneration?</h2>
      <section class="cards-container">
        <article class="card">
          <figure class="card-icon">
            <img src="/imagens/icon plant.svg" alt="Energia limpa">
          </figure>
          <h3>Energia Limpa</h3>
          <p>Reduza sua pegada de carbono com soluções solares portáteis.</p>
        </article>
        <article class="card">
          <figure class="card-icon">
            <img src="/imagens/icone econom.svg" alt="Economia">
          </figure>
          <h3>Economia Real</h3>
          <p>Pague menos na conta de energia com soluções acessíveis.</p>
        </article>
        <article class="card">
          <figure class="card-icon">
            <img src="/imagens/icone raio.svg" alt="Autonomia">
          </figure>
          <h3>Autonomia</h3>
          <p>Não dependa da rede elétrica para o que é essencial.</p>
        </article>
      </section>
    </section>

    <!-- ===== COMO FUNCIONA ===== -->
    <section class="como-funciona">
      <h2>Como funciona?</h2>
      <p class="como-subtitulo">Três passos simples para sua autonomia energética</p>
      <section class="passos-grid">
        <article class="passo-card">
          <span class="passo-num">01</span>
          <h3>Faça o diagnóstico</h3>
          <p>Responda 5 perguntas rápidas sobre sua rotina energética.</p>
        </article>
        <article class="passo-card">
          <span class="passo-num">02</span>
          <h3>Receba recomendações</h3>
          <p>Descubra seu nível de autonomia e veja produtos ideais para você.</p>
        </article>
        <article class="passo-card">
          <span class="passo-num">03</span>
          <h3>Compre com confiança</h3>
          <p>Produtos curados, portáteis e de fácil instalação.</p>
        </article>
      </section>
      <a href="/diagnostico" class="btn-cta">Iniciar diagnóstico gratuito</a>
    </section>

    <!-- ===== PRODUTOS EM DESTAQUE ===== -->
    <section class="produtos-destaque-section" aria-labelledby="produtos-destaque">
      <h2 id="produtos-destaque">Produtos em Destaque</h2>
      <p class="section-sub">Nossas soluções mais populares</p>
      <section class="produtos-grid-home">
        <% if (produtosDestaque && produtosDestaque.length > 0) { %>
          <% produtosDestaque.forEach(function(produto) { %>
            <article class="produto-card-home">
              <figure>
                <img src="/imagens/<%= produto.imagem_produto %>" alt="<%= produto.nome_produto %>">
              </figure>
              <h3><%= produto.nome_produto %></h3>
              <a href="/produto/<%= produto.id_produto %>" class="btn-ver">Ver produto</a>
            </article>
          <% }); %>
        <% } else { %>
          <div class="sem-produtos">
            <p>Não há produtos em destaque no momento. Visite a EcoLoja para ver todos os produtos.</p>
          </div>
        <% } %>
      </section>
      <a href="/ecoloja" class="btn-cta btn-cta-outline">Ver todos os produtos</a>
    </section>

    <!-- ===== BANNER ECOLOJA ===== -->
    <section class="banner-ecoloja">
      <a href="/ecoloja">
        <img src="/imagens/ECOLOJA.svg" alt="Ir para a EcoLoja" class="ecoloja-img">
      </a>
    </section>

  </main>

  <%- include("../partials/footer") %>
  <script src="/js/index.js"></script>
</body>
</html>
