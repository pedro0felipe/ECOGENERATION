<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Criar Conta — EcoGeneration</title>
  <meta name="description" content="Crie sua conta gratuita na EcoGeneration e salve seu histórico de diagnósticos energéticos.">
  <meta name="robots" content="noindex, follow">
  <link rel="stylesheet" href="/css/header.css">
  <link rel="stylesheet "href="/css/login.css">
  <link rel="stylesheet" href="/css/cadastro.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="apple-touch-icon" href="/imagens/favicon2.png">
  <link rel="icon" href="/imagens/favicon2.png" type="image/png">
  <meta property="og:locale" content="pt_BR">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Criar Conta — EcoGeneration">
  <meta property="og:description" content="Crie sua conta e salve seu histórico de diagnósticos energéticos.">
  <meta property="og:url" content="https://ecogeneration-final-4hh3.onrender.com/cadastro">
  <meta property="og:site_name" content="EcoGeneration">
  <meta property="og:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="EcoGeneration — Criar Conta">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Criar Conta — EcoGeneration">
  <meta name="twitter:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#2e7d32">
</head>

 <%- include("../partials/header") %>

<body class="layout">



  <main id="conteudo-principal" tabindex="-1">

    <h1 class="ui header">Formulário de Cadastro</h1>

    <% if (errors.geral) { %>
      <section role="alert" aria-live="assertive" class="erro-geral">
        <p><%= errors.geral.msg %></p>
      </section>
    <% } %>

    <form action="/cadastro" method="post" class="ui form" id="cadastro-form" novalidate aria-label="Formulário de cadastro">

      <label for="nome">Nome Completo <span aria-hidden="true">*</span></label>
      <input
        type="text"
        id="nome"
        name="nome"
        value="<%= old.nome ? old.nome : '' %>"
        placeholder="Digite seu nome completo"
        autocomplete="name"
        required
        aria-required="true"
        aria-describedby="<%= errors.nome ? 'erro-nome' : '' %>"
        aria-invalid="<%= errors.nome ? 'true' : 'false' %>"
      />
      <% if (errors.nome) { %>
        <p id="erro-nome" role="alert" class="campo-erro"><%= errors.nome.msg %></p>
      <% } %>

      <label for="email">E-mail <span aria-hidden="true">*</span></label>
      <input
        type="email"
        id="email"
        name="email"
        value="<%= old.email ? old.email : '' %>"
        placeholder="Digite seu e-mail"
        autocomplete="email"
        required
        aria-required="true"
        aria-describedby="<%= errors.email ? 'erro-email' : '' %>"
        aria-invalid="<%= errors.email ? 'true' : 'false' %>"
      />
      <% if (errors.email) { %>
        <p id="erro-email" role="alert" class="campo-erro"><%= errors.email.msg %></p>
      <% } %>

      <label for="senha">Senha <span aria-hidden="true">*</span></label>
      <div class="campo-senha-wrapper">
        <input
          type="password"
          id="senha"
          name="senha"
          placeholder="Mínimo 6 caracteres"
          autocomplete="new-password"
          required
          aria-required="true"
          aria-describedby="dica-senha <%= errors.senha ? 'erro-senha' : '' %>"
          aria-invalid="<%= errors.senha ? 'true' : 'false' %>"
        />
      </div>
      <label class="mostrar-senha-label">
        <input type="checkbox" onchange="toggleSenha('senha', this)"> Mostrar senha
      </label>
      <p id="dica-senha" class="campo-dica">A senha deve ter no mínimo 6 caracteres.</p>
      <% if (errors.senha) { %>
        <p id="erro-senha" role="alert" class="campo-erro"><%= errors.senha.msg %></p>
      <% } %>

      <label for="confirmar-senha">Confirmar Senha <span aria-hidden="true">*</span></label>
      <div class="campo-senha-wrapper">
        <input
          type="password"
          id="confirmar-senha"
          name="confirmar_senha"
          placeholder="Confirme sua senha"
          autocomplete="new-password"
          required
          aria-required="true"
          aria-describedby="<%= errors.confirmar_senha ? 'erro-confirmar-senha' : '' %>"
          aria-invalid="<%= errors.confirmar_senha ? 'true' : 'false' %>"
        />
      </div>
      <label class="mostrar-senha-label">
        <input type="checkbox" onchange="toggleSenha('confirmar-senha', this)"> Mostrar senha
      </label>
      <% if (errors.confirmar_senha) { %>
        <p id="erro-confirmar-senha" role="alert" class="campo-erro"><%= errors.confirmar_senha.msg %></p>
      <% } %>

      <label for="cpf">CPF <span aria-hidden="true">*</span></label>
      <input
        type="text"
        id="cpf"
        name="cpf"
        data-mask="cpf"
        value="<%= old.cpf ? old.cpf : '' %>"
        placeholder="000.000.000-00"
        maxlength="14"
        required
        aria-required="true"
        aria-describedby="<%= errors.cpf ? 'erro-cpf' : '' %>"
        aria-invalid="<%= errors.cpf ? 'true' : 'false' %>"
        autocomplete="off"
      />
      <% if (errors.cpf) { %>
        <p id="erro-cpf" role="alert" class="campo-erro"><%= errors.cpf.msg %></p>
      <% } %>

      <button type="submit" class="ui primary button">Cadastrar</button>
      <button type="reset" class="ui button">Limpar</button>
    </form>
  </main>

  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/cleave.js@1.6.0/dist/cleave.min.js"></script>
  <script src="/js/mascaras.js"></script>
  <script src="/js/validation.js"></script>
  <script src="/js/senha-toggle.js"></script>
</body>
</html>
