<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="keywords" content="cadastro, criar conta, energia solar, autonomia energética, sustentabilidade">
  <meta name="description" content="Crie sua conta na EcoGeneration e salve seu histórico de diagnósticos energéticos.">
  <title>Cadastro — EcoGeneration</title>
  <!-- Semantic UI CDN -->
  
  <link rel="stylesheet" href="/css/header.css" >
  <link rel="stylesheet" href="/css/login.css" >
  <link rel="stylesheet" href="/css/cadastro.css" >
  <link rel="stylesheet" href="/css/style.css" >
  <link rel="apple-touch-icon" href="/imagens/favicon2.png">
  <link rel="icon" href="/imagens/favicon2.png" type="image/png">

  <!-- Open Graph (OG) — cartão de visitas nas redes sociais -->
  <meta property="og:locale" content="pt_BR">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Criar Conta — EcoGeneration">
  <meta property="og:description" content="Crie sua conta e salve seu histórico de diagnósticos energéticos.">
  <meta property="og:url" content="https://ecogeneration-final-4hh3.onrender.com">
  <meta property="og:site_name" content="EcoGeneration">
  <meta property="og:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <meta property="og:image:secure_url" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="EcoGeneration — Autonomia Energética">
  <!-- Twitter/X Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Criar Conta — EcoGeneration">
  <meta name="twitter:description" content="Crie sua conta e salve seu histórico de diagnósticos energéticos.">
  <meta name="twitter:image" content="https://ecogeneration-final-4hh3.onrender.com/imagens/og-cover-v2.png">
  <!-- PWA -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#2e7d32">
  <!-- Cleave.js CDN for input masks -->
  <script src="https://cdn.jsdelivr.net/npm/cleave.js@1.6.0/dist/cleave.min.js"></script>
</head>
  <%- include("../partials/header") %>
<body class="layout">

  


  <main>
    <h1 class="ui header">Formulário de Cadastro</h1> 
    <form action="/cadastro" method="post" class="ui form" id="cadastro-form">
      
      
      <label for="nome">Nome Completo</label>
      <input
        type="text"
        id="nome"
        name="nome"
        value="<%= old.nome ? old.nome : '' %>"
        placeholder="Digite seu nome completo"
      />
      <% if (errors.nome) { %>
      <section class="ui pointing red basic label"><%= errors.nome.msg %></section>
      <% } %>

      <label for="email">E-mail</label>
      <input
        type="email"
        id="email"
        name="email"
        value="<%= old.email ? old.email : '' %>"
        placeholder="Digite seu e-mail"
      />
      <% if (errors.email) { %>
      <section class="ui pointing red basic label"><%= errors.email.msg %></section>
      <% } %>

      <label for="cpf">CPF (Opcional)</label>
      <input
        type="text"
        id="cpf"
        name="cpf"
        data-mask="cpf"
        value="<%= old.cpf ? old.cpf : '' %>"
        placeholder="000.000.000-00"
        maxlength="14"
      />
      <% if (errors.cpf) { %>
      <section class="ui pointing red basic label"><%= errors.cpf.msg %></section>
      <% } %>

      <label for="cnpj">CNPJ (Opcional)</label>
      <input
        type="text"
        id="cnpj"
        name="cnpj"
        data-mask="cnpj"
        value="<%= old.cnpj ? old.cnpj : '' %>"
        placeholder="00.000.000/0000-00"
        maxlength="18"
      />
      <% if (errors.cnpj) { %>
      <section class="ui pointing red basic label"><%= errors.cnpj.msg %></section>
      <% } %>

      <label for="telefone">Telefone (Opcional)</label>
      <input
        type="text"
        id="telefone"
        name="telefone"
        data-mask="phone"
        value="<%= old.telefone ? old.telefone : '' %>"
        placeholder="(XX) XXXXX-XXXX"
        maxlength="14"
      />
      <% if (errors.telefone) { %>
      <section class="ui pointing red basic label"><%= errors.telefone.msg %></section>
      <% } %>

      <label for="rg">RG (Opcional)</label>
      <input
        type="text"
        id="rg"
        name="rg"
        data-mask="rg"
        value="<%= old.rg ? old.rg : '' %>"
        placeholder="0.000.000-00"
        maxlength="12"
      />
      <% if (errors.rg) { %>
      <section class="ui pointing red basic label"><%= errors.rg.msg %></section>
      <% } %>

      <label for="senha">Senha</label>
      <input
        type="password"
        id="senha"
        name="senha"
        placeholder="Digite sua senha"
      />
      <% if (errors.senha) { %>
      <section class="ui pointing red basic label"><%= errors.senha.msg %></section>
      <% } %>

      <label for="confirmar-senha">Confirmar Senha</label>
      <input
        type="password"
        id="confirmar-senha"
        name="confirmar_senha"
        placeholder="Confirme sua senha"
      />
      <!-- validação frontend exibirá mensagens dinamicamente; não há bloco de erro server-side duplicado aqui -->

      


     
      <p>
        <button type="submit" class="ui primary button">Cadastrar</button>
        <button type="reset" class="ui button">Limpar</button>
      </p>
     
    </form>
  </main>
<footer> 2025-Ecogeneration </footer>
  <script src="/js/validation.js"></script>
  <script src="/js/mascaras.js"></script>
  <!-- Semantic UI JS CDN -->
  <!-- <script src="https://cdn.jsdelivr.net/npm/semantic-ui@2.4.2/dist/semantic.min.js"></script> -->
  <script>

  </script>
</body>
</html>

